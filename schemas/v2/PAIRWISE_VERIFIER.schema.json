{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certa.local/schemas/v2/PAIRWISE_VERIFIER.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "b0_candidate_id",
    "b0_candidate_hash",
    "alternative_candidate_id",
    "alternative_candidate_hash",
    "differing_node_id",
    "b0_node_state",
    "alternative_node_state",
    "artifact_refs",
    "decision"
  ],
  "properties": {
    "b0_candidate_id": {"type": "string", "pattern": "^CAND-[0-9a-f]{64}$"},
    "b0_candidate_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "alternative_candidate_id": {"type": "string", "pattern": "^CAND-[0-9a-f]{64}$"},
    "alternative_candidate_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "differing_node_id": {
      "enum": [
        "ROLE",
        "BINDING",
        "OPERATION",
        "EXECUTION",
        "PROJECTION",
        "STRUCTURAL_CHALLENGE"
      ]
    },
    "b0_node_state": {"enum": ["FAIL", "UNKNOWN"]},
    "alternative_node_state": {"const": "PASS"},
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "decision": {
      "enum": ["ALTERNATIVE_DOMINATES", "NO_DOMINANCE", "UNKNOWN"]
    }
  }
}
